generator client {
  provider = "prisma-client-js"
  output   = "../prisma/generated-client"
}

datasource db {
  provider = "postgresql"
  // url removed for Prisma v7, handled in prisma.config.ts
}

enum Role {
  ADMIN
  TEAM
  SPECTATOR
}

enum Category {
  CP
  WEB
  C
  PYTHON
}

enum SubmissionStatus {
  ACQUIRED
  TESTING
  VERIFIED
  FAILED
}

enum AuctionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

model Team {
  id           String         @id @default(uuid())
  name         String         @unique
  accessKey    String         @unique
  password     String
  credits      Int            @default(1000)
  role         Role           @default(TEAM)
  isEliminated Boolean        @default(false)
  strikes      Int            @default(0)
  lastStrikeAt DateTime?
  members      Member[]
  creditLogs   CreditLog[]
  bids         Bid[]
  submissions  Submission[]
  auctionWins  AuctionRound[] @relation("AuctionWinner")

  // Vault Phase Results
  vaultTime     Int? @default(0) // in seconds
  lifelinesUsed Int  @default(0)
  lockPenalties Int  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GlobalPhase {
  AUCTION
  CODING
  VAULT
  FINISHED
}

model SystemState {
  id              String      @id @default("CURRENT_STATE")
  currentPhase    GlobalPhase @default(AUCTION)
  codingStartTime DateTime?
  updatedAt       DateTime    @updatedAt
}

model Member {
  id     String @id @default(uuid())
  name   String
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model CreditLog {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  createdAt DateTime @default(now())
}

model Snippet {
  id            String         @id @default(uuid())
  title         String         @unique
  category      Category
  buggyCode     String         @db.Text
  solution      String         @db.Text
  hiddenInput   String?        @db.Text
  expected      String?        @db.Text
  isActive      Boolean        @default(true)
  order         Int            @default(0)
  bids          Bid[]
  submissions   Submission[]
  auctionRounds AuctionRound[]
}

model Bid {
  id             String        @id @default(uuid())
  teamId         String
  team           Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  snippetId      String
  snippet        Snippet       @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  auctionRoundId String?
  auctionRound   AuctionRound? @relation(fields: [auctionRoundId], references: [id], onDelete: Cascade)
  amount         Int
  won            Boolean       @default(false)
  createdAt      DateTime      @default(now())
}

model Submission {
  id         String           @id @default(uuid())
  teamId     String
  team       Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  snippetId  String
  snippet    Snippet          @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  code       String           @db.Text
  status     SubmissionStatus @default(ACQUIRED)
  stdout     String?          @db.Text
  stderr     String?          @db.Text
  solverName String?
  solverRole String?
  createdAt  DateTime         @default(now())
}

model AuctionRound {
  id         String        @id @default(uuid())
  snippetId  String
  snippet    Snippet       @relation(fields: [snippetId], references: [id])
  status     AuctionStatus @default(PENDING)
  startTime  DateTime?
  endTime    DateTime?
  duration   Int           @default(120)
  winnerId   String?
  winner     Team?         @relation("AuctionWinner", fields: [winnerId], references: [id])
  winningBid Int?
  bids       Bid[]
  createdAt  DateTime      @default(now())
}
